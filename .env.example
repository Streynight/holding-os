# OpenAI — required for GPT worker
OPENAI_API_KEY=sk-...

# Anthropic — required for Claude worker, smart router, and title generation
ANTHROPIC_API_KEY=sk-ant-...

# Upstash Redis — required for conversation persistence
# Add the Upstash Redis integration in the Vercel Marketplace, it auto-injects these
UPSTASH_REDIS_REST_URL=https://...upstash.io
UPSTASH_REDIS_REST_TOKEN=...

# Clerk — required for authentication
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=pk_test_...
CLERK_SECRET_KEY=sk_test_...
