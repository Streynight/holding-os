# OpenAI — required for GPT-5.5 and GPT-mini workers
OPENAI_API_KEY=sk-...

# Anthropic — required for Claude worker, smart router, and title generation
ANTHROPIC_API_KEY=sk-ant-...

# Vercel KV (Upstash Redis) — required for conversation persistence
# Automatically injected by Vercel when you add a KV store in the dashboard
KV_REST_API_URL=https://...upstash.io
KV_REST_API_TOKEN=...
